        <mxCell id="e_files" value="stages source &amp; test files" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#143d2b;fontColor=#5d665d;fontSize=10;exitX=1;exitY=0.3;entryX=0;entryY=0.4;labelBackgroundColor=#fbfaf7;" edge="1" parent="1" source="repo" target="views">
