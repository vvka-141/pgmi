# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Windows NUL device artifact
nul

# Build output
bin/
dist/
pgmi

# Hugo website build artifacts
website/public/
website/resources/
.hugo_build.lock
.hugo-cache-review/
.hugo-public-review/
.hugo-server/
.tools/
.playwright-mcp/

# Local Go build/test cache (GOCACHE)
.gocache/

# Local Go module cache (GOMODCACHE)
.gomodcache/

# Test binary, built with `go test -c`
*.test

# Python bytecode artifacts (e.g. from compiling the MCP gateway template)
__pycache__/
*.pyc

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# env file
.env

# Claude Code artifacts (proprietary - keep locally only)
.claude/

# Other coding-assistant artifacts (keep locally only)
.agents/
.codex/

# Coding-assistant instructions (proprietary - keep locally only)
CLAUDE.md
AGENTS.md

# Private assets (code reviews, design docs, change requests)
.private/

# Editor/IDE
# .idea/
# .vscode/

# Content and articles (local drafts, not tracked)
/content/

# Test scaffolds (pgmi init output during development)
test_*/
.user/
